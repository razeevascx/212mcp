# Trading 212 API Configuration
TRADING212_API_KEY=your_api_key_here
TRADING212_API_SECRET=your_api_secret_here
# Optional override if you prefer precomputed header:
# TRADING212_AUTH_HEADER=Basic base64_api_key_colon_api_secret
# Legacy fallback (not recommended for public v0):
# TRADING212_API_TOKEN=your_legacy_token_here
ENVIRONMENT=live
TRANSPORT=stdio

# Optional
LOG_LEVEL=info
DEBUG=false
